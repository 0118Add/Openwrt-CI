--- /dev/null
+++ b/sfe_compat.h
@@ -0,0 +1,196 @@
+/*
+ * sfe_compat.h
+ *	Compatibility shims for building SFE on vanilla Linux kernels.
+ *	Provides stubs for Qualcomm-specific kernel extensions.
+ *	Real implementations ported from dd-wrt kernel where available.
+ *
+ * This file is NOT part of upstream QSDK. It is added as a patch to allow
+ * compilation on standard OpenWrt/Linux kernels without QCA kernel patches.
+ */
+#ifndef _SFE_COMPAT_H_
+#define _SFE_COMPAT_H_
+
+#include <linux/version.h>
+#include <linux/netdevice.h>
+#include <linux/skbuff.h>
+#include <net/rtnetlink.h>
+#include <net/dst.h>
+#include <net/route.h>
+
+/*
+ * ip_route_output - kernel 6.12 added 'scope' as 6th arg.
+ * QSDK SFE calls with 5 args. Wrap to add RT_SCOPE_UNIVERSE.
+ */
+#define ip_route_output(net, daddr, saddr, tos, oif) \
+	ip_route_output_compat(net, daddr, saddr, tos, oif)
+
+static inline struct rtable *ip_route_output_compat(struct net *net,
+						    __be32 daddr,
+						    __be32 saddr,
+						    u8 tos, int oif)
+{
+	struct flowi4 fl4 = {
+		.flowi4_oif = oif,
+		.flowi4_tos = tos,
+		.flowi4_scope = RT_SCOPE_UNIVERSE,
+		.daddr = daddr,
+		.saddr = saddr,
+	};
+	return ip_route_output_key(net, &fl4);
+}
+
+/*
+ * linux/debug_mem_usage.h - QCA debug memory tracking.
+ */
+#define mem_debug_update_skb(skb) do {} while(0)
+
+/*
+ * priv_flags_ext - QCA extension to struct net_device.
+ * Map to priv_flags so the struct member access compiles.
+ */
+#define priv_flags_ext priv_flags
+#define IFF_EXT_MAPT 0
+#define IFF_EXT_ETH_L2TPV3 0
+
+/*
+ * vlan_dev_next_dev - QCA helper for walking stacked VLAN devices.
+ * Not present in dd-wrt kernel. vlan_dev_real_dev() goes to the
+ * underlying real device, functionally equivalent for single-level VLAN.
+ */
+#define vlan_dev_next_dev(dev) vlan_dev_real_dev(dev)
+
+/*
+ * netif_is_gre / netif_is_ip6gre
+ * Derived from netif_is_gretap() in include/net/gre.h (dd-wrt kernel).
+ * Check rtnl_link_ops->kind for "gre" / "ip6gre".
+ */
+#ifndef netif_is_gre
+static inline bool netif_is_gre(const struct net_device *dev)
+{
+	return dev->rtnl_link_ops &&
+	       !strcmp(dev->rtnl_link_ops->kind, "gre");
+}
+#endif
+#ifndef netif_is_ip6gre
+static inline bool netif_is_ip6gre(const struct net_device *dev)
+{
+	return dev->rtnl_link_ops &&
+	       !strcmp(dev->rtnl_link_ops->kind, "ip6gre");
+}
+#endif
+
+/*
+ * IPPROTO_ETHERIP - EtherIP protocol number (RFC 3378).
+ */
+#ifndef IPPROTO_ETHERIP
+#define IPPROTO_ETHERIP 97
+#endif
+
+/*
+ * dev_fast_xmit - Real implementation from dd-wrt kernel (net/core/dev.c:4436).
+ * Fast xmit path that bypasses qdisc layer for accelerated forwarding.
+ * Directly locks TX queue and calls netdev_start_xmit().
+ */
+static inline bool dev_fast_xmit(struct sk_buff *skb,
+				 struct net_device *dev,
+				 netdev_features_t features)
+{
+	struct netdev_queue *txq;
+	u16 queue_index;
+	int cpu;
+	netdev_tx_t rc;
+
+	if (unlikely(!(dev->flags & IFF_UP))) {
+		return false;
+	}
+
+	if (unlikely(skb_needs_linearize(skb, features))) {
+		return false;
+	}
+
+	rcu_read_lock_bh();
+	cpu = smp_processor_id();
+
+	/* If device doesn't need the dst, release it now, otherwise make sure
+	 * the refcount increased.
+	 */
+	if (likely(dev->priv_flags & IFF_XMIT_DST_RELEASE)) {
+		skb_dst_drop(skb);
+	} else {
+		skb_dst_force(skb);
+	}
+
+	queue_index = netdev_pick_tx(dev, skb, NULL);
+	txq = netdev_get_tx_queue(dev, queue_index);
+
+	if (likely(txq->xmit_lock_owner != cpu)) {
+		HARD_TX_LOCK(dev, txq, cpu);
+		if (likely(!netif_xmit_stopped(txq))) {
+			rc = netdev_start_xmit(skb, dev, txq, 0);
+			if (unlikely(!dev_xmit_complete(rc))) {
+				HARD_TX_UNLOCK(dev, txq);
+				goto fail;
+			}
+			HARD_TX_UNLOCK(dev, txq);
+			rcu_read_unlock_bh();
+			return true;
+		}
+		HARD_TX_UNLOCK(dev, txq);
+	}
+fail:
+	rcu_read_unlock_bh();
+	return false;
+}
+
+/*
+ * dev_fast_xmit_qdisc - QCA fast xmit with qdisc support.
+ * Not present in dd-wrt kernel. Returns false to fall through
+ * to standard dev_queue_xmit() path.
+ */
+static inline bool dev_fast_xmit_qdisc(struct sk_buff *skb,
+					struct net_device *dev,
+					struct net_device *qdisc_dev)
+{
+	return false;
+}
+
+/*
+ * dev_kfree_skb_list_fast - QCA fast skb list free.
+ * Vanilla kernel equivalent: __skb_queue_purge() — standard batch purge,
+ * no per-element spinlock overhead (unlike skb_dequeue loop).
+ */
+static inline void dev_kfree_skb_list_fast(struct sk_buff_head *list)
+{
+	__skb_queue_purge(list);
+}
+
+/*
+ * netdev_hw_offload_ops - QCA hardware offload ops struct.
+ * Forward declaration so pointers compile.
+ */
+struct netdev_hw_offload_ops;
+
+/*
+ * linux/if_trustsec.h - Cisco/QCA TrustSec SGT header.
+ */
+struct trustsec_hdr {
+	u8 meta_hdr_ver;
+	u8 meta_hdr_len;
+	__be16 payload_len;
+	u8 payload_opt_type;
+	__be16 sgt;
+};
+#define TRUSTSEC_META_HDR_VERSION 0
+#define TRUSTSEC_META_HDR_LEN 0
+#define TRUSTSEC_PAYLOAD_LEN 0
+#define TRUSTSEC_PAYLOAD_OPT_TYPE 0
+#define ETH_P_TRSEC 0
+static inline struct trustsec_hdr *trustsec_get_hdr(struct sk_buff *skb)
+{
+	return (struct trustsec_hdr *)skb->data;
+}
+static inline void trustsec_insert_hdr(struct sk_buff *skb, __be16 sgt)
+{
+}
+
+#endif /* _SFE_COMPAT_H_ */
