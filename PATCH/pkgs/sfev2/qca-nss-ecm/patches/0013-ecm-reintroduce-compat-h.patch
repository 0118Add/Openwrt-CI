+/* ip_route_output Compat */
+static inline struct rtable *ecm_compat_ip_route_output(struct net *net, __be32 daddr, __be32 saddr, u8 tos, int oif)
+{
+       struct flowi4 fl4 = {
+               .daddr = daddr,
+               .saddr = saddr,
+               .flowi4_tos = tos,
+               .flowi4_oif = oif,
+       };
+       return ip_route_output_flow(net, &fl4, NULL);
+}
