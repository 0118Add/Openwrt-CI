+/* Bridge Compat */
+static inline struct net_device *ecm_compat_br_port_dev_get(struct net_device *br, struct sk_buff *skb)
+{
+       struct net_device *dev;
+       
+       if (!skb) return NULL;
+
+       /* Try to get input device from skb->skb_iif (Standard Linux behavior) */
+       rcu_read_lock();
+       dev = dev_get_by_index_rcu(dev_net(br), skb->skb_iif);
+       
+       if (dev) {
+               /* Verify if this device is a port of the bridge 
+                * Use netdev_master_upper_dev_get_rcu to replace dev->master check
+                */
+               if (netdev_master_upper_dev_get_rcu(dev) != br) {
+                       dev = NULL;
+               }
+       }
+       rcu_read_unlock();
+
+       return dev;
+}
+
+#define br_port_dev_get(br, addr, cookie, len) ecm_compat_br_port_dev_get(br, skb)
+
+/* 
+ * br_fdb_has_entry replacement:
+ * Use the exported br_fdb_find_port (GPL) to check if the bridge knows the destination.
+ * Returns true only if a valid forwarding port is found.
+ */
+static inline bool ecm_compat_br_fdb_has_entry(struct net_device *br_dev, const unsigned char *addr, __u16 vid)
+{
+       /* br_fdb_find_port returns the port net_device if found and state is FORWARDING */
+       return !!br_fdb_find_port(br_dev, addr, vid);
+}
+#define br_fdb_has_entry(dev, addr, vid) ecm_compat_br_fdb_has_entry(dev, addr, vid)
