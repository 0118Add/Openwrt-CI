+/* UDP Timeouts Compat */
+/* 
+ * udp_get_timeouts() is a dd-wrt/QCA kernel export not present in vanilla.
+ * Use nf_udp_pernet() (available in vanilla 6.12 via nf_conntrack_l4proto.h)
+ * to dynamically read the actual per-net UDP timeouts, including any
+ * user-customized values via sysctl.
+ */
+static inline unsigned int *udp_get_timeouts(struct net *net)
+{
+       return nf_udp_pernet(net)->timeouts;
+}
